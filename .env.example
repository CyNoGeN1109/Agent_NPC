# Copy to .env and fill in. The real .env is gitignored — never commit it.

# --- Brain (pick ONE path) ---
# Cloud: an OpenRouter key enables free models out of the box.
OPENROUTER_API_KEY=
# Optional overrides:
# OPENROUTER_MODEL=tencent/hy3:free
# OPENROUTER_FALLBACKS=nvidia/nemotron-nano-9b-v2:free,openai/gpt-oss-20b:free

# Local (no key needed): just run Ollama or LM Studio and leave the key blank.
# NPC_BACKEND=ollama            # force local even if a key is set
# NPC_MODEL=qwen2.5:3b

# --- Voice (optional) ---
# macOS `say` is used automatically on a Mac — no config needed.
# NPC_SAY_VOICE=Rishi           # Indian-accented English voice
# NPC_SAY_VOICE_HI=Lekha        # Hindi voice, used for Devanagari replies

# PORT=7777
